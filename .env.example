# ── Shared DB password ─────────────────────────────────────────────────────────
# Used by all three services. Change before deploying.
DB_PASSWORD=change-me-in-production

# ── Service-to-service secret ──────────────────────────────────────────────────
# Must be the same across all three services.
# Challenge-service sends this when calling quest-service /quests/generate-internal.
# Also protects /admin/seed and /admin/content endpoints.
SERVICE_SECRET=change-me-to-something-long-and-random

# Quest Service also uses this to call challenge:
QUEST_SERVICE_SECRET=change-me-to-something-long-and-random

# ── LLM configuration ──────────────────────────────────────────────────────────
# Controls which LLM backend is used for quest generation (fallback) and KELA boss.
#
# Options:
#   auto       → use Anthropic if ANTHROPIC_API_KEY is set, else Ollama
#   anthropic  → force Claude Haiku (cloud, costs money)
#   ollama     → force Ollama (local or same-server, free)
#   none       → disable LLM entirely (wordbank only for quests, KELA boss disabled)
LLM_BACKEND=auto

# Anthropic API key — only needed if LLM_BACKEND=anthropic or LLM_BACKEND=auto
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Ollama settings — only needed if LLM_BACKEND=ollama or LLM_BACKEND=auto without Anthropic key
# If Ollama runs on the Docker host (macOS/Windows):
#   OLLAMA_HOST=http://host.docker.internal:11434
# If Ollama runs on the same Linux VPS as Docker:
#   OLLAMA_HOST=http://172.17.0.1:11434  (Docker bridge gateway IP)
# If Ollama runs as a separate container (add to docker-compose):
#   OLLAMA_HOST=http://ollama:11434
OLLAMA_HOST=http://host.docker.internal:11434
# OLLAMA_MODEL=phi3.5:3.8b  # optional — leave blank to let FATG auto-detect based on your hardware

# ── CORS ───────────────────────────────────────────────────────────────────────
# Set to your actual frontend URL in production
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Boss fight settings ────────────────────────────────────────────────────────
PLAYER_MAX_HP=100
AI_MAX_HP=100
AI_FLAT_DAMAGE=15
KELA_MIN_DECK_SIZE=6
