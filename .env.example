# ─App
APP_NAME=lingo-python-service
APP_VERSION=0.1.0
DEBUG=false

# Database
# This service has its own Postgres instance - it never touches the Node.js DB
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://lingo:lingo@python-db:5432/lingo_python
DATABASE_ECHO=false

# Security
# Shared secret between Node.js backend and this service
# Node must send this in the x-service-secret header on every request
SERVICE_SECRET=change-me-to-something-long-and-random

# ─LLM
# Get this from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# challenge setting
CHALLENGE_PACK_SIZE=5
FUZZY_MATCH_THRESHOLD=0.75

# battle setting
PLAYER_MAX_HP=100
AI_MAX_HP=100
AI_FLAT_DAMAGE=15
MAX_BATTLE_TURNS=12
KELA_MIN_DECK_SIZE=6

# Cors
# In production set this to your actual frontend URL
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
